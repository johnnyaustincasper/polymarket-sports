# Athlete Intelligence local/production environment
# Copy to .env.local for development. Do not commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth: Clerk is the preferred production account provider.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Legacy/session auth fallback used by guest/local/login routes.
AUTH_SESSION_SECRET=
SESSION_SECRET=
ENABLE_GUEST_ACCESS=true
AUTHORIZED_EMAILS=
AUTHORIZED_USERS_JSON=
AUTH_INVITE_CODE=
APP_PASSWORD=

# Billing: Stripe checkout, portal, and webhook handling.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# AI: xAI/Grok is primary. Anthropic is preserved as optional legacy/fallback.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini
XAI_FULLSCAN_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_FULLSCAN_MODEL=claude-sonnet-4-5

# Optional future OpenAI-compatible fallback. Not required by current production routes.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Search enrichment. Routes degrade without Brave.
BRAVE_API_KEY=

# X live context. Use an X Developer app bearer token for recent-search receipts.
# Accepted aliases in code: X_API_BEARER_TOKEN, X_BEARER_TOKEN, TWITTER_BEARER_TOKEN.
X_API_BEARER_TOKEN=

# Durable cache/profile storage. Use one Redis/KV family in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_READONLY_TOKEN=
REDIS_REST_API_URL=
REDIS_REST_API_TOKEN=
DURABLE_CACHE_PREFIX=athlete-intel
KV_CACHE_PREFIX=
PROFILE_STORE_FILE=.data/profiles.json

# Rate limiting overrides.
API_RATE_LIMIT_REQUESTS=
API_RATE_LIMIT_WINDOW_MS=

# No env required: ESPN public APIs, Kalshi public APIs, Polymarket public APIs.
