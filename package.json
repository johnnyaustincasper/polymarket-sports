    "react-dom": "^19.2.6",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
